# =============================================
# ROOMLINK ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# =============================================

# --- Supabase ---
# Get these from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- JWT Secret (make this long and random) ---
JWT_SECRET=make_this_very_long_and_random_at_least_64_characters

# --- Paystack ---
# Get these from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# --- App Config ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# --- When you go live, change these to production values ---
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PUBLIC_KEY=pk_live_...
# NODE_ENV=production
# FRONTEND_URL=https://yourdomain.com
